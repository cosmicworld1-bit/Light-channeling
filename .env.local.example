# Copy to .env.local for local development, and set the same keys in
# Vercel project settings for deployment. Never commit the real values.

# Google AI Studio API key (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Shared passcode you'll type once in the browser to unlock the app.
APP_PASSCODE=

# Random long string used to sign the session cookie. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# Filled in during the CRM read-tool phase.
CRM_BASE_URL=https://volunteers.lightchannels.com
CRM_USERNAME=
CRM_PASSWORD=

# Filled in during the new-session intake phase. E.164 format, digits only
# (e.g. 919876543210 for an Indian number), no leading +.
WHATSAPP_COORDINATOR_NUMBER=
